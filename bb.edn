{:paths ["." "src" "test"]
 :tasks
 {test {:doc "Run tsutae murakumo actor boundary tests"
        :task (do
                (require 'clojure.test
                         'tsutae.murakumo-test)
                (let [run-tests (requiring-resolve 'clojure.test/run-tests)
                      r (run-tests 'tsutae.murakumo-test)]
                  (System/exit (if (zero? (+ (:fail r) (:error r))) 0 1))))}}}
