    "adoption": "manufacturing methodology adopted",
    "rejection": "proprietary IP + closed firmware + surveillance hardware + addictive UX + mass-production-at-any-cost explicitly rejected per Charter Rider §2(b) + §2(c) + §2(d) + §2(e)"
  },
