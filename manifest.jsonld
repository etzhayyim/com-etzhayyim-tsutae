  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605261300. Changes require Council Lv6+ supermajority + new ADR.",
    "gates": {
      "G1": "All hardware open-source — PCB Gerbers + chassis CAD (FreeCAD .fcstd) + cable HDL + schematic netlist public Apache 2.0 + Charter Rider",
      "G2": "All firmware open-source — bootloader (U-Boot/coreboot) + OS kernel (Linux mainline) + userspace (AOSP-derivative/GrapheneOS class); bootloader unlock = default",
      "G3": "Repair-rightful — modular screw-fastened; adhesive ≤5g/assembly (target 0g); replaceable battery+display+camera+USB-C+speaker+SIM+cellular+microphone; iFixit ≥9/10",
      "G4": "Witness quorum ≥2 robot signers (Mimi AOI + Otete handling) per deviceAttestation Ed25519",
      "G5": "Bilingual (JA+EN) iFixit-class repair manual public; SOPs + BoM disclosure + Charter Rider per device shipped",
      "G6": "§2(c) anti-surveillance — cellular module hardware-removable (physical screw-mount); Wi-Fi-default boot; IMEI never broadcast while cellular disconnected; microphone hardware kill switch mandatory; biometric open-firmware (no SEP/Knox enclave)",
      "G7": "Firmware binary blob ratio ≤5% by mass; every blob = vendor + reason + replacement-effort estimate + Council waiver",
      "G8": "§2(d) anti-addiction UX — calm-default OS; notification batching ≥15 min default; no infinite-scroll OS primitive; no dopamine-loop API; screen-time aggregate self-report only; no auto-play media on lock screen",
      "G9": "§2(b) anti-IP locking — open SoC mandatory: R1 = third-party open RISC-V (StarFive JH7110 / SiFive Unmatched / Allwinner D1); R2+ = iwakura SoC; Snapdragon/Apple A/closed Helio/closed Exynos NEVER",
      "G10": "Battery — Li-ion LFP-preferred (safety + recyclability + cycle life); user-replaceable hand tools; take-back recycling ≥80% by R3 (kanayama); no battery serial-locking / no parts pairing",
      "G11": "§1.13 Wellbecoming — screen-time aggregate self-report only; no per-user behavioral telemetry; OS provides focus/sabbath mode primitive",
      "G12": "Production rate ≤200 devices / 8-hr line R3 (anti-mass-production; no Samsung-class scale)",
      "G13": "Murakumo mesh 30-day prior notice + 1 km community feedback (RF + supply chain visibility + EOL take-back logistics)",
      "G14": "Every device = open serial + DID + IPFS-pinned BoM + repair-history-ready blockchain record (per-device DID accepts repairEvent records throughout lifecycle)"
    }
  },
  "nonGoals": {
    "description": "12 explicitly excluded scopes (+2 over igata's 10 reflecting smartphone-specific §2(c) + §2(d) risks)",
    "goals": {
      "N1": "Proprietary SoC (Snapdragon / Apple A / closed Helio / closed Exynos / Dimensity closed BSP) — NEVER (§2(b); G9 invariant)",
      "N2": "Closed bootloader (Samsung Knox / Apple SEP / Qualcomm Secure Boot / closed Exynos boot ROM) — NEVER (§2(b); G2)",
      "N3": "Mandatory cellular modem (always-on / IMEI broadcast by default / soldered modem) — NEVER (§2(c); G6)",
      "N4": "Always-on surveillance sensors (mic wake-word / closed-fw fingerprint / always-on camera / proximity logging) — NEVER (§2(c))",
      "N5": "Addictive UX patterns (infinite-scroll OS-API / dopamine notification / dark pattern API / auto-play lock-screen / streak-style) — NEVER (§2(d); G8)",
      "N6": "Licensed IP partnerships (Disney/Sanrio/sports/anime co-branding) — NEVER (§2(b); makura N8 parity)",
      "N7": "Proprietary glue assembly (Apple/Samsung trend; pentalobe screws; parts-pairing serial lock) — NEVER (§2(e); G3)",
      "N8": "Mass production ≥100,000 units/year R3 (Samsung-class scale) — post-R3 + Council Lv6+ supermajority (igata N1 parity)",
      "N9": "External commercial sale to non-adherent — SBT↔SBT internal carve-out only (ADR-2605192115 §3)",
      "N10": "Carrier-locked SIM / region-locked firmware / SIM-pairing — NEVER (§2(e) anti-gatekeeping)",
      "N11": "Adware OS / bloatware preload / mandatory account creation (Google/Apple/Samsung ID) — NEVER (§2(b) + §2(d))",
      "N12": "AI / cloud-mandatory features (cloud sync default-on / mandatory OTA / mandatory account-bound activation / voice-assistant cloud routing) — NEVER (§2(c))"
    }
  },
